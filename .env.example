# Variables de entorno para CletaEats Backend
# Copia este archivo a .env y ajusta los valores.
# En Railway/Render, configura estas variables en el panel web (NO subas .env al repo).

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=8080

# Base de datos MySQL
DB_URL=jdbc:mysql://localhost:3306/cletaeats?serverTimezone=UTC
DB_USER=root
DB_PASSWORD=root
